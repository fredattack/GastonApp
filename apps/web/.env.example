# =============================================================================
# GastonApp Web Application - Environment Variables
# =============================================================================
#
# Copy this file to `.env` in the same directory and fill in your actual values.
# NEVER commit the actual `.env` file to version control.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API Configuration
# -----------------------------------------------------------------------------

# The base URL of your backend API server
# Development: Usually http://localhost:8000 or your Laravel backend URL
# Production: Your production API domain (e.g., https://api.gastonapp.com)
# Required: Yes
VITE_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Firebase Configuration
# -----------------------------------------------------------------------------
# Get these values from your Firebase Console:
# https://console.firebase.google.com/ > Project Settings > General > Your apps
#
# Firebase is used for:
# - Authentication (user login/signup)
# - Firestore database (data storage)
# - Cloud Storage (file uploads)

# Firebase API Key
# Required: Yes (if using Firebase features)
# Example: AIzaSyB1234567890abcdefghijklmnopqrstuvw
VITE_FIREBASE_API_KEY=

# Firebase Auth Domain
# Required: Yes (if using Firebase features)
# Example: your-project-id.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=

# Firebase Project ID
# Required: Yes (if using Firebase features)
# Example: your-project-id
VITE_FIREBASE_PROJECT_ID=

# Firebase Storage Bucket
# Required: Yes (if using Firebase Storage)
# Example: your-project-id.appspot.com
VITE_FIREBASE_STORAGE_BUCKET=

# Firebase Messaging Sender ID
# Required: No (only if using Firebase Cloud Messaging)
# Example: 123456789012
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Firebase App ID
# Required: Yes (if using Firebase features)
# Example: 1:123456789012:web:abcdef1234567890abcdef
VITE_FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# Error Tracking & Monitoring
# -----------------------------------------------------------------------------

# Bugsnag API Key for error tracking and performance monitoring
# Get your API key from: https://app.bugsnag.com/settings/YOUR_ORG/projects
# Required: No (application will work without it, but errors won't be tracked)
# Leave empty in development if you don't want to send errors to Bugsnag
VITE_BUGSNAG_API_KEY=

# -----------------------------------------------------------------------------
# AI & Machine Learning
# -----------------------------------------------------------------------------

# OpenAI API Key for AI-powered features
# Get your API key from: https://platform.openai.com/api-keys
# Required: No (AI features will be disabled if not provided)
# Note: Currently, the app uses the backend API for AI features,
#       so this key might be configured on the backend instead
VITE_OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------

# Port for the development server (optional, defaults to 4480)
# VITE_PORT=4480

# -----------------------------------------------------------------------------
# Security Notes
# -----------------------------------------------------------------------------
#
# 1. NEVER commit your actual `.env` file to version control
# 2. Keep your API keys secure and rotate them regularly
# 3. Use different Firebase projects for development and production
# 4. In production, use environment variables from your hosting provider
# 5. For Docker deployments, pass these as environment variables in docker-compose.yml
#
# -----------------------------------------------------------------------------
